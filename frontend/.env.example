# Copy to `.env` and adjust for your environment.

# Base URL of the FastAPI backend (no trailing slash).
VITE_API_BASE_URL=http://localhost:8000

# Must match the backend's API_AUTH_TOKEN (see ../.env.example). Leave empty
# if the backend has no API_AUTH_TOKEN set (auth disabled in dev/staging).
#
# SECURITY NOTE: this value is bundled into the client-side JS and is
# visible to anyone who loads the page — acceptable for an internal demo/
# interview build talking to a dev backend, but do NOT reuse this pattern
# for a public-facing production deployment. A real production setup should
# proxy requests through a backend-for-frontend that holds the secret
# server-side instead of shipping it to the browser.
VITE_API_KEY=
