# =============================================================================
# AI Newsletter Automation - Environment Configuration
# Copy this file to `.env` and fill in real values. Every external
# integration has a mock/fallback implementation, so the application runs
# end-to-end (with sample/mocked data) even before keys are added.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Shared secret Power Automate must send as `X-API-Key` when calling
# POST /generate-newsletter. Leave empty to disable auth on non-production envs.
API_AUTH_TOKEN=change-me-to-a-long-random-secret

# ---------------------------------------------------------------------------
# LLM Provider: openai | azure_openai | mock
# `mock` requires no credentials and is used automatically when no API key
# is configured, so the pipeline is always runnable and testable.
# ---------------------------------------------------------------------------
LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# ---------------------------------------------------------------------------
# News source providers (all optional - unset keys fall back to the mock
# provider for that source so collection never hard-fails).
# ---------------------------------------------------------------------------

# NewsAPI.org - used by GlobalNewsAgent and PolicyAgent as a supplementary source
NEWSAPI_API_KEY=

# GitHub - raises unauthenticated rate limits for OpenSourceAgent (60 -> 5000 req/hr)
GITHUB_TOKEN=

# Crunchbase - used by FundingAgent
CRUNCHBASE_API_KEY=

# Talent sources - public job board APIs, no key required.
# Comma-separated list of company board tokens/slugs to query.
GREENHOUSE_BOARD_TOKENS=stripe,airbnb,openai
LEVER_COMPANY_SLUGS=netflix,palantir

# LinkedIn Jobs has no public API; abstraction defaults to `mock`.
# Set to `api` only if you have an authorized LinkedIn Talent/Partner integration.
LINKEDIN_JOBS_PROVIDER=mock
LINKEDIN_API_KEY=

# ---------------------------------------------------------------------------
# Deduplication & Ranking
# ---------------------------------------------------------------------------
DEDUP_SIMILARITY_THRESHOLD=0.88

RANKING_TOP_STORIES_PER_SECTION=5
RANKING_WEIGHT_FRESHNESS=0.20
RANKING_WEIGHT_IMPORTANCE=0.25
RANKING_WEIGHT_BUSINESS_IMPACT=0.20
RANKING_WEIGHT_SOURCE_CREDIBILITY=0.15
RANKING_WEIGHT_RESEARCH_IMPACT=0.10
RANKING_WEIGHT_AI_RELEVANCE=0.10

# ---------------------------------------------------------------------------
# Newsletter
# ---------------------------------------------------------------------------
NEWSLETTER_TIMEZONE=UTC
NEWSLETTER_SENDER_NAME=AI Newsletter Automation
NEWSLETTER_HISTORY_DIR=data/history
MAX_ARTICLE_AGE_HOURS=48

# ---------------------------------------------------------------------------
# HTTP / networking
# ---------------------------------------------------------------------------
HTTP_TIMEOUT_SECONDS=15
HTTP_MAX_RETRIES=3
